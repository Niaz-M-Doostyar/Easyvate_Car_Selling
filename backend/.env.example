# ============================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and update values as needed
# ============================================================================

# Environment
NODE_ENV=development

# Server Configuration
PORT=5001
HOST=localhost

# Database Configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=easyvate_cars
DB_PORT=3306

# JWT Configuration
JWT_SECRET=easyvate_secret_key_2026
JWT_EXPIRY=24h

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# Logging
LOG_LEVEL=info

# Features
AUTO_CREATE_ADMIN=true
AUTO_SYNC_DB=true

# ============================================================================
# NOTES:
# - Update DB_* values to match your MySQL configuration
# - Keep JWT_SECRET secure in production
# - Set CORS_ORIGIN to your frontend URL in production
# - Use separate values for development and production
# ============================================================================
